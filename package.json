{
  "name": "local-music-player",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "npm run build:electron && concurrently -k \"vite --host 127.0.0.1\" \"sh -c 'wait-on http://127.0.0.1:5173 dist-electron/electron/main.js && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .'\"",
    "dev:vite": "vite --host 127.0.0.1",
    "build:electron": "rm -rf dist-electron && tsc -p tsconfig.node.json",
    "build": "npm run build:electron && tsc -b && vite build",
    "build:mac": "node scripts/build-macos-app.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -b --noEmit",
    "electron": "electron ."
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "music-metadata": "^10.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/ui": "^2.1.0",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "jsdom": "^25.0.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.11",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.0",
    "electron": "^35.0.0",
    "@vitejs/plugin-react": "^4.3.4"
  }
}
